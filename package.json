{
  "name": "tweakability",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A dependency-free, code-split real-time parameter panel — sliders, toggles, a wide-gamut OKLCH colour picker, curve editors and more, from a plain schema.",
  "license": "MIT",
  "author": "Ryan Kiley",
  "scripts": {
    "build": "node build.mjs",
    "prepublishOnly": "node build.mjs",
    "serve": "node build.mjs && python3 -m http.server 4330 --directory dist"
  },
  "types": "./dist/types/tweaks/single.d.ts",
  "exports": {
    ".": { "types": "./dist/types/tweaks/single.d.ts", "import": "./dist/tweaks.js" },
    "./core": { "types": "./dist/types/tweaks/core.d.ts", "import": "./dist/tweaks/core.js" },
    "./css": "./dist/tweaks.css"
  },
  "files": [
    "dist/tweaks",
    "dist/tweaks.js",
    "dist/tweaks.css",
    "dist/types",
    "src",
    "THIRD-PARTY-NOTICES.md"
  ],
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3"
  }
}
